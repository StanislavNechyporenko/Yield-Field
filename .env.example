# WalletConnect Cloud project id — https://cloud.walletconnect.com
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=your_project_id

# 'mainnet' — live Monad mainnet data, deposits via protocol sites (non-custodial)
# 'testnet' — demo list + one-click MON deposits through our testnet contract
NEXT_PUBLIC_NETWORK_MODE=mainnet

# Monad RPC endpoints (frontend)
NEXT_PUBLIC_MONAD_RPC_TESTNET=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_RPC_MAINNET=https://rpc.monad.xyz

# Monad RPC endpoints (hardhat)
MONAD_RPC_TESTNET=https://testnet-rpc.monad.xyz
MONAD_RPC_MAINNET=https://rpc.monad.xyz

# Deployer private key — TESTNET ONLY, never commit the real value
PRIVATE_KEY=

# Deployed contract addresses (fill in after `npm run deploy:testnet`)
NEXT_PUBLIC_AGGREGATOR_ADDRESS=
# YieldZapRouter on Monad mainnet (deploy with `npx hardhat run scripts/deploy-router.js --network monadMainnet`)
NEXT_PUBLIC_ROUTER_ADDRESS=
NEXT_PUBLIC_INVEST_ASSET_ADDRESS=

# Optional: addresses auto-registered by scripts/deploy.js when set
AAVE_POOL_ADDRESS=
MORPHO_VAULT_ADDRESS=
INVEST_ASSET_ADDRESS=
